generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id Int @default(autoincrement()) @id
  name String @db.VarChar(150)
  lastname String @db.VarChar(150)
  username String @db.VarChar(150) @unique
  password String 
  createdAt DateTime @default(now()) @map("create_at")
  tasks Task[]
}

model Task {
  id Int   @id @default(autoincrement())
  name String
  description String
  priority Boolean
  userId Int
  user User @relation(fields: [userId], references: [id])
}

model logs{
  id Int @id @default (autoincrement())
  statusCode Int
  timestamp DateTime
  path String @db.Text
  error String @db.Text
  errorCode String @db.Text

  session_id Int?

  user User? @relation (fields: [session_id], references: [id])
}