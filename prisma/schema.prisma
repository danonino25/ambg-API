generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// 1. Definición de Roles (Requisito: "Tiene que tener 2 roles")
enum Role {
  ADMIN
  USER
}

model User {
  id        Int      @id @default(autoincrement())
  name      String   @db.VarChar(150)
  lastname  String   @db.VarChar(150)
  username  String   @unique @db.VarChar(150) // Validación de usuario repetido (Unique)
  password  String
  role      Role     @default(USER)          // Campo para roles
  create_at DateTime @default(now())
  logs      Logs[]
  tasks     Task[]
}

model Task {
  id          Int     @id @default(autoincrement())
  name        String
  description String
  priority    Boolean
  completed   Boolean @default(false)
  userId      Int
  user        User    @relation(fields: [userId], references: [id]) // Relación para que el user vea solo sus tareas
}

// 2. Módulo de Auditoría y LOGS (Requisito: Registro de eventos y acciones)
model Logs {
  id          Int      @id @default(autoincrement())
  statusCode  Int?     // Para errores de sistema
  timestamp   DateTime @default(now())
  path        String?  // Ruta donde ocurrió el evento
  
  // Nuevos campos para auditoría detallada
  action      String?  // Acciones: "LOGIN", "ELIMINACION", "ACTUALIZACION", "CAMBIO_ROL"
  description String?  // Detalles: "El admin cambió el rol de X" o "Tarea creada"
  error       String?  // Mensaje de error si falló algo
  errorCode   String?
  
  // Relación con el usuario (quién realizó la acción)
  session_id  Int?
  user        User?    @relation(fields: [session_id], references: [id])
}