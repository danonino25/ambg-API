generator client {
  provider = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        Int      @id @default(autoincrement())
  name      String   @db.VarChar(150)
  lastname  String   @db.VarChar(150)
  username  String   @unique @db.VarChar(150)
  password  String
  hash      String?
  create_at DateTime @default(now())
  logs      Logs[]
  tasks     Task[]
}

model Task {
  id          Int     @id @default(autoincrement())
  name        String
  description String
  priority    Boolean
  completed   Boolean @default(false)
  userId      Int
  user        User    @relation(fields: [userId], references: [id])
}

model Logs {
  id         Int      @id @default(autoincrement())
  statusCode Int
  timestamp  DateTime
  path       String
  error      String
  errorCode  String
  session_id Int?
  user       User?    @relation(fields: [session_id], references: [id])
}
